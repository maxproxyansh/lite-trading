APP_NAME=Lite Options Terminal
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGIN_REGEX=^https://(litetrade|lite-options-terminal)(-[a-z0-9-]+)?\\.vercel\\.app$
LITE_DATABASE_URL=sqlite:///../data/lite.db
JWT_SECRET=change-me
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
ALLOW_PUBLIC_SIGNUP=false
BOOTSTRAP_ADMIN_EMAIL=admin@lite.trade
BOOTSTRAP_ADMIN_PASSWORD=change-me
BOOTSTRAP_ADMIN_NAME=Lite Admin
BOOTSTRAP_AGENT_KEY=change-me
BOOTSTRAP_AGENT_NAME=default-agent
SIGNAL_ROOT=../signals
AUTO_EXECUTE_SIGNALS=false
SIGNAL_MIN_CONFIDENCE=60
MARKET_POLL_SECONDS=5
SIGNAL_POLL_SECONDS=15
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
